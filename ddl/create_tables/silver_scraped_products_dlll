/*  

DLL for the cleaned data from the raw at source silver_scraped_products. 

*/ 

create table if not exists public.silver_scraped_products (
    id bigserial primary key,

    -- link back to raw layer
    raw_scrape_id bigint not null,
    scrape_run_id text,
    source_name text not null default 'amazon',
    source_url text,
    source_category text,

    -- core cleaned product fields
    product_title text,
    product_title_normalized text,
    product_rank integer,
    price_amount numeric(12,2),
    currency_code text default 'GBP',
    rating_value numeric(3,2),
    review_count integer,
    image_url text,

    -- optional product metadata
    brand text,
    marketplace text default 'amazon.co.uk',
    product_url text,
    sku text,
    asin text,

    -- validation / quality
    is_valid boolean not null default true,
    validation_errors jsonb,
    cleaning_notes jsonb,

    -- dedupe / matching
    dedupe_key text,
    source_hash text,
    is_latest boolean not null default true,

    -- processing metadata
    cleaned_at timestamptz not null default now(),
    created_at timestamptz not null default now(),
    updated_at timestamptz not null default now(),

    -- optional raw snapshot of cleaned record
    cleaned_snapshot jsonb,

    constraint fk_silver_scraped_products_raw_scrape
        foreign key (raw_scrape_id)
        references public.raw_amazon_products(id)
        on delete cascade
);
